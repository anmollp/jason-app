project_id = "your-gcp-project-id"
region     = "us-central1"

service_name = "jason"

# Use image URIs from Artifact Registry after images have been pushed.
frontend_image = "us-central1-docker.pkg.dev/your-gcp-project-id/jason-dev-containers/frontend:latest"
backend_image  = "us-central1-docker.pkg.dev/your-gcp-project-id/jason-dev-containers/backend:latest"

# Cost-control defaults for individual hosting.
frontend_min_instances = 0
frontend_max_instances = 1
backend_min_instances  = 0
backend_max_instances  = 1

frontend_cpu    = "1"
frontend_memory = "512Mi"
backend_cpu     = "1"
backend_memory  = "512Mi"

jason_cli_path                   = "/usr/local/bin/jason"
frontend_allow_unauthenticated  = true
github_repository                = "anmollp/jason-app"
github_ref                       = "refs/heads/master"

budget_amount_usd = 10
billing_account_id = ""
